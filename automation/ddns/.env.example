# Copy to automation/ddns/.env and adjust values.

# Hostname to validate/update.
DDNS_HOSTNAME=k8s.sebastianmeyer.org

# IONOS DynDNS update URL from DNS record settings.
# Use placeholders {host} and {ip} if your URL supports it.
# Example:
# DDNS_UPDATE_URL="https://example.provider/update?hostname={host}&myip={ip}&token=YOUR_TOKEN"
DDNS_UPDATE_URL=""

# Optional settings
DNS_RESOLVER=1.1.1.1
LOG_FILE=/tmp/ddns-sync.log
LOCK_FILE=/tmp/ddns-sync.lock

# Optional webhook for failures (Slack/Discord-compatible incoming webhook).
# ALERT_WEBHOOK_URL="https://hooks.example.com/services/..."
